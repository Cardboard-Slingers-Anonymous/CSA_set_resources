# Copy this file to secrets.toml and fill in your Supabase credentials.
# secrets.toml is gitignored and should never be committed.

[supabase]
url = "https://your-project-id.supabase.co"
key = "your-anon-key-here"
# For local dev use http://localhost:8501
# For Streamlit Cloud use your deployed app URL
redirect_url = "http://localhost:8501"
